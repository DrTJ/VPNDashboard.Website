@page "/connected"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@implements IDisposable
@inject VPNDashboard.Website.Services.OpenVpnReader Reader

<PageTitle>Connected Clients - VPN Dashboard</PageTitle>

<div class="app-content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-6"><h3 class="mb-0">Connected Clients</h3></div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h3 class="card-title">
            Live Connections
            <span class="badge text-bg-@(_clients.Count > 0 ? "success" : "secondary") ms-2">
                @_clients.Count online
            </span>
        </h3>
        <div class="card-tools">
            <span class="badge text-bg-success">
                <i class="bi bi-circle-fill me-1" style="font-size: 0.5rem"></i>
                Live — refreshes every 5s
            </span>
        </div>
    </div>
    <div class="card-body p-0">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Client</th>
                    <th>Real IP</th>
                    <th>Virtual IP</th>
                    <th>Received</th>
                    <th>Sent</th>
                    <th>Connected Since</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var client in _clients)
                {
                    <tr>
                        <td>
                            <i class="bi bi-person-check text-success me-1"></i>
                            @client.CommonName
                        </td>
                        <td><code>@client.RealAddress</code></td>
                        <td><code>@client.VirtualAddress</code></td>
                        <td>@FormatBytes(client.BytesReceived)</td>
                        <td>@FormatBytes(client.BytesSent)</td>
                        <td>@client.ConnectedSince.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    </tr>
                }
                @if (!_clients.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            <i class="bi bi-wifi-off me-2"></i>No clients currently connected
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<ConnectedClient> _clients = new();
    private Timer? _timer;

    protected override void OnInitialized()
    {
        _clients = Reader.GetConnectedClients();
        _timer = new Timer(PollClients, null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));
    }

    private void PollClients(object? state)
    {
        try
        {
            _clients = Reader.GetConnectedClients();
            InvokeAsync(StateHasChanged);
        }
        catch
        {
            // Ignore polling errors
        }
    }

    private static string FormatBytes(long bytes)
    {
        string[] sizes = ["B", "KB", "MB", "GB", "TB"];
        double b = bytes;
        int order = 0;
        while (b >= 1024 && order < sizes.Length - 1)
        {
            order++;
            b /= 1024;
        }
        return $"{b:0.##} {sizes[order]}";
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}
