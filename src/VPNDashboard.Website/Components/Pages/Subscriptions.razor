@page "/subscriptions"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject SubscriptionService Subs
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Subscriptions - VPN Dashboard</PageTitle>

<div class="app-content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-6"><h3 class="mb-0">Subscriptions</h3></div>
            <div class="col-sm-6 text-end">
                <button class="btn btn-primary" @onclick="ShowCreateDialog">
                    <i class="bi bi-plus-circle me-1"></i> New Subscription
                </button>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert @(_messageIsError ? "alert-danger" : "alert-success") alert-dismissible">
        <button type="button" class="btn-close" @onclick="() => _message = null"></button>
        @_message
    </div>
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title">All Subscriptions</h3>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th>Profile</th>
                        <th>Schedule</th>
                        <th>Starts</th>
                        <th>Ends</th>
                        <th>Status</th>
                        <th>Notes</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in _items)
                    {
                        <tr>
                            <td>
                                <i class="bi bi-person me-1"></i>
                                <strong>@s.ProfileName</strong>
                            </td>
                            <td>
                                @if (s.ScheduleType == ScheduleType.Unlimited)
                                {
                                    <span class="badge text-bg-secondary">Unlimited</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-info">Periodic</span>
                                }
                            </td>
                            <td>@FormatDate(s.StartDate, fallback: "Immediate")</td>
                            <td>@FormatDate(s.EndDate, fallback: "—")</td>
                            <td>@StatusBadge(s)</td>
                            <td class="text-muted small" style="max-width:240px">
                                @if (!string.IsNullOrWhiteSpace(s.LastError))
                                {
                                    <span class="text-danger" title="@s.LastError">
                                        <i class="bi bi-exclamation-triangle"></i> Last error
                                    </span>
                                }
                                else
                                {
                                    @s.Notes
                                }
                            </td>
                            <td class="text-end">
                                @if (s.Status == SubscriptionStatus.Pending || s.Status == SubscriptionStatus.Active)
                                {
                                    <button class="btn btn-sm btn-outline-secondary me-1"
                                            @onclick="() => ShowEditDialog(s)" disabled="@_busy">
                                        <i class="bi bi-pencil"></i> Edit
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger"
                                            @onclick="() => ConfirmCancel(s)" disabled="@_busy">
                                        <i class="bi bi-x-circle"></i> Cancel
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                    @if (_items.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">No subscriptions yet</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (_showEditor)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editing is null ? "New Subscription" : "Edit Subscription")</h5>
                    <button type="button" class="btn-close" @onclick="() => _showEditor = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Profile name</label>
                        <input type="text" class="form-control" @bind="_form.ProfileName"
                               disabled="@(_editing is not null)"
                               placeholder="e.g. phone, laptop, john" />
                        <div class="form-text">Letters, numbers, hyphens and underscores only.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Schedule</label>
                        <div class="d-flex gap-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" id="schedUnlimited"
                                       checked="@(_form.ScheduleType == ScheduleType.Unlimited)"
                                       @onchange="() => SetScheduleType(ScheduleType.Unlimited)" />
                                <label class="form-check-label" for="schedUnlimited">Unlimited</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" id="schedPeriodic"
                                       checked="@(_form.ScheduleType == ScheduleType.Periodic)"
                                       @onchange="() => SetScheduleType(ScheduleType.Periodic)" />
                                <label class="form-check-label" for="schedPeriodic">Periodic</label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Start (local time)</label>
                        <input type="datetime-local" class="form-control"
                               @bind="_form.StartLocal"
                               disabled="@(_editing is not null && _editing.Status == SubscriptionStatus.Active)" />
                        <div class="form-text">Leave empty to start immediately.</div>
                    </div>

                    @if (_form.ScheduleType == ScheduleType.Periodic)
                    {
                        <div class="mb-3">
                            <label class="form-label">End (local time)</label>
                            <input type="datetime-local" class="form-control" @bind="_form.EndLocal" />

                            <div class="mt-2 d-flex flex-wrap gap-2">
                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                        @onclick="() => SetEndDuration(TimeSpan.FromDays(1))">+1 day</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                        @onclick="() => SetEndDuration(TimeSpan.FromDays(7))">+1 week</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                        @onclick="() => SetEndDuration(TimeSpan.FromDays(30))">+30 days</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                        @onclick="() => SetEndDuration(TimeSpan.FromDays(90))">+90 days</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                        @onclick="() => SetEndDuration(TimeSpan.FromDays(365))">+1 year</button>
                            </div>
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label">Notes</label>
                        <textarea class="form-control" rows="2" maxlength="500" @bind="_form.Notes"></textarea>
                    </div>

                    @if (!string.IsNullOrEmpty(_formError))
                    {
                        <div class="alert alert-danger mb-0">@_formError</div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _showEditor = false" disabled="@_busy">Cancel</button>
                    <button class="btn btn-primary" @onclick="SubmitForm" disabled="@_busy">
                        @if (_busy)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        @(_editing is null ? "Create" : "Save")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_cancelTarget is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Cancel subscription</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => _cancelTarget = null"></button>
                </div>
                <div class="modal-body">
                    <p>Cancel the subscription for <strong>@_cancelTarget.ProfileName</strong>?</p>
                    @if (_cancelTarget.Status == SubscriptionStatus.Active)
                    {
                        <p class="text-danger mb-0">The OpenVPN profile will be revoked immediately.</p>
                    }
                    else
                    {
                        <p class="text-muted mb-0">This subscription has not been activated yet, so no certificate will be revoked.</p>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _cancelTarget = null" disabled="@_busy">Keep</button>
                    <button class="btn btn-danger" @onclick="ConfirmCancelExecute" disabled="@_busy">
                        @if (_busy)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Cancel subscription
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Subscription> _items = new();
    private bool _showEditor;
    private bool _busy;
    private string? _message;
    private bool _messageIsError;
    private string? _formError;

    private Subscription? _editing;
    private Subscription? _cancelTarget;

    private FormModel _form = new();

    private class FormModel
    {
        public string ProfileName { get; set; } = string.Empty;
        public ScheduleType ScheduleType { get; set; } = ScheduleType.Unlimited;
        public DateTime? StartLocal { get; set; }
        public DateTime? EndLocal { get; set; }
        public string? Notes { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await Reload();
    }

    private async Task Reload()
    {
        _items = await Subs.GetAllAsync();
    }

    private void ShowCreateDialog()
    {
        _editing = null;
        _form = new FormModel();
        _formError = null;
        _showEditor = true;
    }

    private void ShowEditDialog(Subscription s)
    {
        _editing = s;
        _form = new FormModel
        {
            ProfileName = s.ProfileName,
            ScheduleType = s.ScheduleType,
            StartLocal = s.StartDate?.ToLocalTime(),
            EndLocal = s.EndDate?.ToLocalTime(),
            Notes = s.Notes,
        };
        _formError = null;
        _showEditor = true;
    }

    private void SetScheduleType(ScheduleType t)
    {
        _form.ScheduleType = t;
        if (t == ScheduleType.Unlimited)
            _form.EndLocal = null;
    }

    private void SetEndDuration(TimeSpan span)
    {
        var anchor = _form.StartLocal is { } sl && sl > DateTime.Now
            ? sl
            : DateTime.Now;
        _form.EndLocal = anchor.Add(span);
    }

    private async Task<string?> CurrentUserIdAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    }

    private async Task SubmitForm()
    {
        _formError = null;
        if (_busy) return;

        DateTime? startUtc = _form.StartLocal?.ToUniversalTime();
        DateTime? endUtc = _form.EndLocal?.ToUniversalTime();

        _busy = true;
        try
        {
            if (_editing is null)
            {
                if (string.IsNullOrWhiteSpace(_form.ProfileName))
                {
                    _formError = "Profile name is required.";
                    return;
                }

                var userId = await CurrentUserIdAsync();
                var result = await Subs.CreateAsync(
                    _form.ProfileName,
                    _form.ScheduleType,
                    startUtc,
                    endUtc,
                    _form.Notes,
                    userId);

                if (!result.Success)
                {
                    _formError = result.Error;
                    return;
                }

                _message = $"Subscription for '{result.Subscription!.ProfileName}' created.";
                _messageIsError = false;
            }
            else
            {
                var result = await Subs.UpdateScheduleAsync(
                    _editing.Id,
                    _form.ScheduleType,
                    startUtc,
                    endUtc,
                    _form.Notes);

                if (!result.Success)
                {
                    _formError = result.Error;
                    return;
                }

                _message = $"Subscription for '{_editing.ProfileName}' updated.";
                _messageIsError = false;
            }

            _showEditor = false;
            await Reload();
        }
        finally
        {
            _busy = false;
        }
    }

    private void ConfirmCancel(Subscription s) => _cancelTarget = s;

    private async Task ConfirmCancelExecute()
    {
        if (_cancelTarget is null || _busy) return;
        _busy = true;
        try
        {
            var result = await Subs.CancelAsync(_cancelTarget.Id);
            if (result.Success)
            {
                _message = $"Subscription for '{_cancelTarget.ProfileName}' cancelled.";
                _messageIsError = false;
            }
            else
            {
                _message = result.Error;
                _messageIsError = true;
            }
            _cancelTarget = null;
            await Reload();
        }
        finally
        {
            _busy = false;
        }
    }

    private static string FormatDate(DateTime? utc, string fallback)
        => utc is null ? fallback : utc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm");

    private static MarkupString StatusBadge(Subscription s)
    {
        var (cls, text) = s.Status switch
        {
            SubscriptionStatus.Pending => ("text-bg-warning", "Pending"),
            SubscriptionStatus.Active => ("text-bg-success", "Active"),
            SubscriptionStatus.Expired => ("text-bg-secondary", "Expired"),
            SubscriptionStatus.Revoked => ("text-bg-danger", "Revoked"),
            _ => ("text-bg-light", s.Status.ToString())
        };
        return new MarkupString($"<span class=\"badge {cls}\">{text}</span>");
    }
}
