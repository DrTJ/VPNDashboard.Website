@page "/server"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject OpenVpnReader VpnReader
@inject OpenVpnAdmin VpnAdmin
@inject OpenVpnInstaller VpnInstaller
@inject NavigationManager Navigation
@using Microsoft.AspNetCore.SignalR.Client

<PageTitle>Server - VPN Dashboard</PageTitle>

<div class="app-content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-6"><h3 class="mb-0">Server Management</h3></div>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert @(_messageIsError ? "alert-danger" : "alert-success") alert-dismissible">
        <button type="button" class="btn-close" @onclick="() => _message = null"></button>
        @_message
    </div>
}

@{
    var status = VpnReader.GetServerStatus();
}

<!-- Server Config Summary -->
<div class="card">
    <div class="card-header">
        <h3 class="card-title"><i class="bi bi-hdd-rack me-2"></i>Server Configuration</h3>
        <div class="card-tools">
            <button class="btn btn-sm btn-outline-primary" @onclick="ReloadServer" disabled="@_busy">
                <i class="bi bi-arrow-clockwise me-1"></i> Reload
            </button>
        </div>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <div class="callout callout-info">
                    <h5>Protocol</h5>
                    <p>@status.Protocol.ToUpperInvariant()</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="callout callout-info">
                    <h5>Port</h5>
                    <p>@status.Port</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="callout callout-info">
                    <h5>Listen Address</h5>
                    <p>@(string.IsNullOrEmpty(status.ListenAddress) ? "0.0.0.0" : status.ListenAddress)</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="callout callout-info">
                    <h5>Subnet</h5>
                    <p>@(string.IsNullOrEmpty(status.Subnet) ? "N/A" : status.Subnet)</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Journal Logs -->
<div class="card">
    <div class="card-header">
        <h3 class="card-title"><i class="bi bi-journal-text me-2"></i>Service Logs</h3>
        <div class="card-tools">
            <button class="btn btn-sm btn-outline-secondary" @onclick="LoadLogs" disabled="@_busy">
                <i class="bi bi-arrow-clockwise"></i> Refresh
            </button>
        </div>
    </div>
    <div class="card-body">
        <pre class="bg-dark text-light p-3 rounded" style="max-height: 400px; overflow-y: auto; font-size: 0.85rem;">@_journalLogs</pre>
    </div>
</div>

<!-- Danger Zone -->
<div class="card card-danger card-outline">
    <div class="card-header">
        <h3 class="card-title text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Danger Zone</h3>
    </div>
    <div class="card-body">
        @if (!_showUninstallLog)
        {
            <p>Completely remove OpenVPN from this server. This will:</p>
            <ul>
                <li>Stop the OpenVPN service</li>
                <li>Remove all firewall rules</li>
                <li>Delete all certificates and keys</li>
                <li>Uninstall the OpenVPN package</li>
            </ul>
            <p class="text-danger fw-bold">This action is irreversible. All connected clients will be disconnected immediately.</p>

            @if (!_showConfirmInput)
            {
                <button class="btn btn-outline-danger" @onclick="() => _showConfirmInput = true">
                    <i class="bi bi-trash me-1"></i> Uninstall OpenVPN
                </button>
            }
            else
            {
                <div class="mb-3">
                    <label class="form-label">Type <strong>UNINSTALL</strong> to confirm:</label>
                    <input type="text" class="form-control" @bind="_confirmText" placeholder="UNINSTALL" style="max-width: 300px" />
                </div>
                <button class="btn btn-danger me-2" @onclick="UninstallOpenVpn"
                        disabled="@(_confirmText != "UNINSTALL" || _busy)">
                    @if (_busy)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    Confirm Uninstall
                </button>
                <button class="btn btn-secondary" @onclick="() => { _showConfirmInput = false; _confirmText = string.Empty; }"
                        disabled="@_busy">
                    Cancel
                </button>
            }
        }
        else
        {
            <h5>Uninstall Progress</h5>
            <pre class="bg-dark text-light p-3 rounded" style="max-height: 400px; overflow-y: auto; font-size: 0.85rem;"
                 @ref="_logElement">@string.Join('\n', _uninstallLogs)</pre>
        }
    </div>
</div>

@code {
    private string? _message;
    private bool _messageIsError;
    private bool _busy;
    private string _journalLogs = "Loading...";
    private bool _showConfirmInput;
    private string _confirmText = string.Empty;
    private bool _showUninstallLog;
    private List<string> _uninstallLogs = new();
    private ElementReference _logElement;
    private HubConnection? _hubConnection;

    protected override async Task OnInitializedAsync()
    {
        await LoadLogs();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _hubConnection = new HubConnectionBuilder()
                .WithUrl(Navigation.ToAbsoluteUri("/hubs/installer"))
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On<string>("InstallerLog", (line) =>
            {
                _uninstallLogs.Add(line);
                InvokeAsync(StateHasChanged);
            });

            _hubConnection.On<bool>("InstallerComplete", (success) =>
            {
                _busy = false;
                if (success)
                {
                    InvokeAsync(() => Navigation.NavigateTo("/setup", forceLoad: true));
                }
                else
                {
                    InvokeAsync(StateHasChanged);
                }
            });

            await _hubConnection.StartAsync();
        }
    }

    private async Task LoadLogs()
    {
        _journalLogs = await VpnReader.GetJournalLogsAsync();
    }

    private async Task ReloadServer()
    {
        _busy = true;
        var (success, output) = await VpnAdmin.ReloadServerAsync();
        _busy = false;

        _message = success ? "Server reloaded successfully." : $"Failed to reload: {output}";
        _messageIsError = !success;

        await LoadLogs();
    }

    private async Task UninstallOpenVpn()
    {
        _busy = true;
        _showUninstallLog = true;
        _uninstallLogs.Clear();

        await VpnInstaller.UninstallAsync();
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
            await _hubConnection.DisposeAsync();
    }
}
